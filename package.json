{
  "name": "whatsapp-browser-controller",
  "version": "0.1.0",
  "description": "Controlador de múltiplas sessões de WhatsApp Web via Playwright, com API interna para integração com n8n.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "playwright": "1.47.0",
    "express": "^4.19.2",
    "bullmq": "^5.12.0",
    "ioredis": "^5.4.1",
    "@supabase/supabase-js": "^2.45.4",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8",
    "express-rate-limit": "^7.4.0",
    "qrcode": "^1.5.4",
    "uuid": "^10.0.0",
    "ws": "^8.21.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "tsx": "^4.19.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.15",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "vitest": "^2.0.5",
    "eslint": "^8.57.0"
  }
}

